<Project>
  <PropertyGroup>
    <RHome>$(R_HOME)</RHome>
    <RInclude>$(RHome)\include</RInclude>
    <RLib>$(RHome)\lib</RLib>
    <NativeLibName>rbridge-native</NativeLibName>
    <NativeDir>$(MSBuildThisFileDirectory)</NativeDir>
  </PropertyGroup>

  <Target Name="BuildNativeLibrary" AfterTargets="Build">
    <MakeDir Directories="$(OutputPath)" />

    <!-- macOS -->
    <Exec Condition="'$(OS)' != 'Windows_NT' AND 
                     '$([System.Runtime.InteropServices.RuntimeInformation]::IsOSPlatform($([System.Runtime.InteropServices.OSPlatform]::OSX)))' == 'True'"
          Command="clang -dynamiclib '$(NativeDir)/native_api.c' -o '$(OutputPath)/lib$(NativeLibName).dylib' -I'$(RInclude)' -L'$(RLib)' -lR -DR_INTERFACE_PTRS" />

    <!-- Linux -->
    <Exec Condition="'$(OS)' != 'Windows_NT' AND 
                     '$([System.Runtime.InteropServices.RuntimeInformation]::IsOSPlatform($([System.Runtime.InteropServices.OSPlatform]::Linux)))' == 'True'"
          Command="gcc -shared -fPIC '$(NativeDir)/native_api.c' -o '$(OutputPath)/lib$(NativeLibName).so' -I'$(RInclude)' -L'$(RLib)' -lR -DR_INTERFACE_PTRS" />

    <!-- Windows -->
    <Exec Condition="'$(OS)' == 'Windows_NT'"
          Command="gcc -shared -fPIC &quot;$(NativeDir)\native_api.c&quot; -o &quot;$(OutputPath)$(NativeLibName).dll&quot; -I&quot;$(RInclude)&quot; -L&quot;$(RLib)&quot; -lR -DR_INTERFACE_PTRS" />  </Target>
</Project>
